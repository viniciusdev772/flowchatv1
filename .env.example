# =====================================================
# BAILEYS MULTI-SESSION API - ENVIRONMENT CONFIGURATION
# =====================================================

# Application Configuration
NODE_ENV=production
PORT=3000

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# MongoDB is INCLUDED in the Docker Compose setup
# The MongoDB container will be automatically created with these credentials
# Change the passwords below for production security

# MongoDB Connection String (uses Docker service names)
MONGODB_URI=mongodb://admin:password123@mongodb:27017/baileys?authSource=admin
DB_NAME=baileys

# MongoDB Root Credentials (for Docker MongoDB container)
# IMPORTANT: Change these passwords in production!
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
# CRITICAL: Generate strong random strings for production!
# You can use: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-change-this-to-random-string
COOKIE_SECRET=your-super-secret-cookie-key-change-this-to-random-string

# CORS Configuration - Set to your production domain
CORS_ORIGIN=http://localhost:3000

# =====================================================
# PRODUCTION DEPLOYMENT EXAMPLE
# =====================================================
# Uncomment and modify these for your production domain:
# CORS_ORIGIN=https://yourdomain.com
# MONGO_ROOT_PASSWORD=your-strong-production-password
# SESSION_SECRET=your-generated-session-secret-32-chars
# COOKIE_SECRET=your-generated-cookie-secret-32-chars