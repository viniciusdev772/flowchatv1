# =====================================================
# BAILEYS MULTI-SESSION API - CONFIGURATION
# =====================================================

# Application Configuration
NODE_ENV=production
PORT=3000
TZ=America/Sao_Paulo

# =====================================================
# DATABASE CONFIGURATION (OPTIONAL)
# =====================================================
# MongoDB for sessions storage (leave empty to use memory store)
# MONGODB_URI=mongodb://mongouser:mongopassword@mongodb:27017/baileys?authSource=admin
# MONGO_ROOT_USER=mongouser
# MONGO_ROOT_PASSWORD=mongopassword
DB_NAME=baileys

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
# Generate strong random strings for production!
# You can use: openssl rand -base64 32
SESSION_SECRET=baileys-default-session-secret-change-in-production
COOKIE_SECRET=baileys-default-cookie-secret-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# =====================================================
# AI ASSISTANT CONFIGURATION
# =====================================================
# OpenAI API Key for AI Assistant functionality
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=