# =====================================================
# BAILEYS MULTI-SESSION API - ENVIRONMENT CONFIGURATION
# =====================================================

# Application Configuration
NODE_ENV=production
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://admin:password123@mongodb:27017/baileys?authSource=admin
DB_NAME=baileys

# MongoDB Root User (for Docker Compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123


# Security Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-to-random-string
COOKIE_SECRET=your-super-secret-cookie-key-change-this-to-random-string

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=50485760
UPLOAD_DIR=uploads
DOWNLOAD_DIR=downloads

# Webhook Configuration
MAX_WEBHOOKS_PER_SESSION=3
WEBHOOK_TIMEOUT=10000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/baileys.log

# WhatsApp Session Configuration
SESSION_TIMEOUT=300000
QR_CODE_TIMEOUT=60000
RECONNECT_ATTEMPTS=5

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Development Settings (uncomment for development)
# NODE_ENV=development
# LOG_LEVEL=debug
# CORS_ORIGIN=http://localhost:5173