# =====================================================
# BAILEYS MULTI-SESSION API - ENVIRONMENT CONFIGURATION
# =====================================================

# Application Configuration
NODE_ENV=production
PORT=3000

# Domain/URL Configuration (Change for production deployment)
API_BASE_URL=http://localhost:3000
DOMAIN=localhost

# Database Configuration
MONGODB_URI=mongodb://admin:password123@mongodb:27017/baileys?authSource=admin
DB_NAME=baileys

# MongoDB Root User (for Docker Compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123

# Security Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-to-random-string
COOKIE_SECRET=your-super-secret-cookie-key-change-this-to-random-string

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Production Example (comment out for local development)
# API_BASE_URL=http://yourdomain.com
# DOMAIN=yourdomain.com
# CORS_ORIGIN=http://yourdomain.com