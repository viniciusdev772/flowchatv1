# =====================================================
# BAILEYS MULTI-SESSION API - PRODUCTION CONFIGURATION
# =====================================================

# Application Configuration
NODE_ENV=production
PORT=3000
TZ=America/Sao_Paulo

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# MongoDB Root Credentials (for Docker MongoDB container)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password123
DB_NAME=baileys

# MongoDB Connection String (auto-configured in docker-compose)
MONGODB_URI=mongodb://admin:password123@mongodb:27017/baileys?authSource=admin

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
# Generate strong random strings for production!
# You can use: openssl rand -base64 32
SESSION_SECRET=baileys-super-secret-session-key-change-in-production
COOKIE_SECRET=baileys-super-secret-cookie-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# =====================================================
# AI ASSISTANT CONFIGURATION
# =====================================================
# OpenAI API Key for AI Assistant functionality
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=