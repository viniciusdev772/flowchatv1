{
  "name": "baileys-multi-session-api",
  "version": "1.0.0",
  "description": "API avançada do WhatsApp com Baileys, multi-sessões e comportamento humano para prevenção de banimentos",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "dev": "nodemon --ext js --watch src --watch main.js --ignore node_modules --ignore uploads --ignore downloads --ignore auth_sessions main.js",
    "frontend": "cd frontend && npx vite",
    "frontend:build": "cd frontend && npx vite build",
    "frontend:preview": "cd frontend && npx vite preview",
    "dev:full": "npx concurrently \"npm run dev\" \"npm run frontend\"",
    "install:frontend": "cd frontend && npm install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "api",
    "multi-session",
    "automation",
    "webhook",
    "express"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.18",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fs-extra": "^11.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "mongodb": "^6.17.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.32.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10"
  }
}
